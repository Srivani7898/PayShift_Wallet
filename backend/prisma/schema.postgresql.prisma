datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum TransactionType {
  SEND
  RECEIVE
  ADD_MONEY
  WITHDRAW
  RECHARGE
  BILL_PAYMENT
  CASHBACK
  REFUND
}

enum TransactionStatus {
  SUCCESS
  FAILED
  PENDING
}

enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RewardType {
  CASHBACK
  POINTS
}

enum RewardStatus {
  CLAIMED
  UNCLAIMED
}

model User {
  id            Int             @id @default(autoincrement())
  uuid          String          @unique @default(uuid())
  fullName      String
  email         String          @unique
  phone         String          @unique
  passwordHash  String
  profileImage  String?
  isVerified    Boolean         @default(false)
  isBlocked     Boolean         @default(false)
  role          Role            @default(USER)
  appLockPin    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  wallet        Wallet?
  upiIds        UPIId[]
  bankAccounts  BankAccount[]
  rewards       Reward[]
  notifications Notification[]
  recharges     RechargeHistory[]
  bills         BillPayment[]
  kycRecord     KYCRecord?
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  
  // Relations as sender/receiver for P2P transactions
  sentTxns      Transaction[]   @relation("SenderTransactions")
  receivedTxns  Transaction[]   @relation("ReceiverTransactions")
}

model Wallet {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  balance       Decimal  @default(18450.75) @db.Decimal(12, 2)
  lockedBalance Decimal  @default(0.00) @db.Decimal(12, 2)
  currency      String   @default("INR")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              Int               @id @default(autoincrement())
  referenceNumber String            @unique
  senderId        Int?
  receiverId      Int?
  amount          Decimal           @db.Decimal(12, 2)
  transactionType TransactionType
  status          TransactionStatus @default(SUCCESS)
  description     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  sender          User?             @relation("SenderTransactions", fields: [senderId], references: [id], onDelete: SetNull)
  receiver        User?             @relation("ReceiverTransactions", fields: [receiverId], references: [id], onDelete: SetNull)
}

model UPIId {
  id         Int      @id @default(autoincrement())
  userId     Int
  upiId      String   @unique
  isPrimary  Boolean  @default(false)
  isVerified Boolean  @default(true)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id            Int      @id @default(autoincrement())
  userId        Int
  bankName      String
  accountNumber String
  ifsc          String
  accountHolder String
  isPrimary     Boolean  @default(false)
  pin           String?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bankName])
}

model Reward {
  id           Int          @id @default(autoincrement())
  userId       Int
  rewardType   RewardType   @default(CASHBACK)
  rewardAmount Decimal      @db.Decimal(10, 2)
  status       RewardStatus @default(UNCLAIMED)
  createdAt    DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RechargeHistory {
  id              Int      @id @default(autoincrement())
  userId          Int
  mobileNumber    String
  operator        String
  circle          String?
  amount          Decimal  @db.Decimal(10, 2)
  status          String   @default("SUCCESS") // SUCCESS, FAILED
  referenceNumber String   @unique
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BillPayment {
  id              Int      @id @default(autoincrement())
  userId          Int
  billerName      String
  billCategory    String // Electricity, Water, Gas, Broadband, Credit Card
  consumerNumber  String
  amount          Decimal  @db.Decimal(10, 2)
  status          String   @default("SUCCESS") // SUCCESS, FAILED
  referenceNumber String   @unique
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KYCRecord {
  id            Int       @id @default(autoincrement())
  userId        Int       @unique
  aadhaarNumber String
  panNumber     String
  aadhaarUrl    String
  panUrl        String
  status        KYCStatus @default(PENDING)
  verifiedAt    DateTime?
  verifiedBy    String?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  details   String?
  userId    Int?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}
