{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "ignoreDeprecations": "5.0"
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "dist",
    "src/tests/**/*",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}